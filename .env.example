# ─── Author Persona ───────────────────────────────────────────────────────────
# Customize these to match your own voice and niche.
# The AI will write posts as YOU, in your style, for your audience.

AUTHOR_NAME=Alex
AUTHOR_ROLE=software engineer
AUTHOR_TOPICS=AI, software development, and tech trends
AUTHOR_AUDIENCE=tech-curious professionals aged 25-45

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey (free tier available)

GEMINI_API_KEY=your_gemini_api_key_here

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Create a bot: open Telegram → search @BotFather → /newbot
# Get your chat ID: message your bot, then visit:
# https://api.telegram.org/bot<TOKEN>/getUpdates

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Google Sheets ────────────────────────────────────────────────────────────
# Create a Google Sheet, then share it with your service account email.
# The Sheet ID is in the URL: docs.google.com/spreadsheets/d/<SHEET_ID>/edit

GOOGLE_SHEET_ID=your_google_sheet_id_here

# Path to your Google service account credentials JSON file.
# Download from Google Cloud Console → IAM → Service Accounts → Keys.
GOOGLE_CREDENTIALS_PATH=credentials.json

# ─── RapidAPI ─────────────────────────────────────────────────────────────────
# Sign up at https://rapidapi.com (free tier available)

RAPIDAPI_KEY=your_rapidapi_key_here

# ─── LinkedIn ─────────────────────────────────────────────────────────────────
# See SETUP.md for step-by-step instructions on getting these values.
# Your access token expires — see SETUP.md for how to refresh it.

LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_PERSON_URN=urn:li:person:your_profile_id_here
